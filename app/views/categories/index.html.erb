<h1>Category</h1>
<%= link_to("Add New category","/categories/new", :class =>'action new') %>
<br/>
<% @categories.each do |category| %>
   <tr>
    <td><%= category.position %></td>
    <td><%= category.name %></td>
    <td class="actions">
        <%= link_to("Show", "/categories/#{category.id}", :class =>'action show') %>
        <%= link_to("Edit", "/categories/#{category.id}/edit", :class =>'action edit') %>
        <%= link_to("Delete", "/categories/#{category.id}/delete", :class =>'action delete') %>
    </td>
   </tr>
 <br/>
        <%end%>
